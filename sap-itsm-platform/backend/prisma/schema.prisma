generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                 String               @id @default(uuid())
  name               String
  slug               String               @unique
  timezone           String               @default("UTC")
  country            String?
  status             TenantStatus         @default(ACTIVE)
  settings           Json?                @default("{}")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  assignmentRules    AssignmentRule[]
  auditLogs          AuditLog[]
  configItems        ConfigurationItem[]
  customers          Customer[]
  emailTemplates     EmailTemplate[]
  holidayCalendars   HolidayCalendar[]
  records            ITSMRecord[]
  notificationRules  NotificationRule[]
  notifications      Notification[]
  sapModules         SAPModuleMaster[]
  sapSubModules      SAPSubModuleMaster[]
  shifts             Shift[]
  slaPolicyMasters   SLAPolicyMaster[]
  supportTypeMasters SupportTypeMaster[]
  users              User[]

  @@map("tenants")
}

model User {
  id                  String                   @id @default(uuid())
  tenantId            String                   @map("tenant_id")
  email               String                   @unique
  passwordHash        String                   @map("password_hash")
  firstName           String                   @map("first_name")
  lastName            String                   @map("last_name")
  role                UserRole                 @default(USER)
  status              UserStatus               @default(PENDING)
  customerId          String?                  @map("customer_id")
  lastLoginAt              DateTime?                @map("last_login_at")
  passwordResetToken       String?                  @unique @map("password_reset_token")
  passwordResetExpiry      DateTime?                @map("password_reset_expiry")
  createdAt                DateTime                 @default(now()) @map("created_at")
  updatedAt                DateTime                 @updatedAt @map("updated_at")
  agent               Agent?
  auditLogs           AuditLog[]
  comments            Comment[]
  customerAdmin       Customer?                @relation("CustomerAdmin")
  createdRecords      ITSMRecord[]             @relation("CreatedBy")
  notificationPrefs   NotificationPreference[]
  notifications       Notification[]
  refreshTokens       RefreshToken[]
  approvedTimeEntries TimeEntry[]              @relation("ApprovedBy")
  customer            Customer?                @relation("CustomerUsers", fields: [customerId], references: [id])
  tenant              Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([email])
  @@index([role])
  @@index([status])
  @@index([customerId])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model Agent {
  id               String                @id @default(uuid())
  userId           String                @unique @map("user_id")
  specialization   String?
  level            AgentLevel            @default(L1)
  timezone         String                @default("UTC")
  maxConcurrent    Int                   @default(5) @map("max_concurrent")
  agentType        AgentType             @default(AGENT) @map("agent_type")
  status           AgentStatus           @default(AVAILABLE)
  metadata         Json?                 @default("{}")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")
  specializations  AgentSpecialization[]
  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  customerAgents   CustomerAgent[]
  managedCustomers Customer[]            @relation("CustomerPM")
  assignments      ITSMRecord[]
  timeEntries      TimeEntry[]

  @@index([status])
  @@index([level])
  @@map("agents")
}

model AgentSpecialization {
  id              String          @id @default(uuid())
  agentId         String          @map("agent_id")
  sapModuleId     String          @map("sap_module_id")
  sapSubModuleIds String[]        @map("sap_sub_module_ids")
  createdAt       DateTime        @default(now()) @map("created_at")
  agent           Agent           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  sapModule       SAPModuleMaster @relation(fields: [sapModuleId], references: [id])

  @@unique([agentId, sapModuleId])
  @@index([agentId])
  @@map("agent_specializations")
}

model AssignmentRule {
  id             String           @id @default(uuid())
  tenantId       String           @map("tenant_id")
  customerId     String           @map("customer_id")
  name           String
  recordType     String?          @map("record_type")
  priority       String?
  sapModuleId    String?          @map("sap_module_id")
  assignmentMode String           @map("assignment_mode")
  preferredLevel String?          @map("preferred_level")
  sortOrder      Int              @default(0) @map("sort_order")
  isActive       Boolean          @default(true) @map("is_active")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  customer       Customer         @relation(fields: [customerId], references: [id])
  sapModule      SAPModuleMaster? @relation(fields: [sapModuleId], references: [id])
  tenant         Tenant           @relation(fields: [tenantId], references: [id])

  @@index([tenantId, customerId])
  @@index([tenantId, customerId, recordType, priority])
  @@map("assignment_rules")
}

model Customer {
  id                    String              @id @default(uuid())
  tenantId              String              @map("tenant_id")
  companyName           String              @map("company_name")
  industry              String?
  country               String?
  timezone              String              @default("UTC")
  status                CustomerStatus      @default(ACTIVE)
  website               String?
  contactName           String?             @map("contact_name")
  contactEmail          String?             @map("contact_email")
  contactPhone          String?             @map("contact_phone")
  billingEmail          String?             @map("billing_email")
  billingAddress        String?             @map("billing_address")
  notes                 String?
  allowedDomains        String[]            @default([]) @map("allowed_domains")
  adminUserId           String?             @unique @map("admin_user_id")
  projectManagerAgentId String?             @map("project_manager_agent_id")
  holidayCalendarId     String?             @map("holiday_calendar_id")
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")
  assignmentRules       AssignmentRule[]
  configurationItems    ConfigurationItem[]
  contracts             Contract[]
  customerAgents        CustomerAgent[]
  adminUser             User?               @relation("CustomerAdmin", fields: [adminUserId], references: [id])
  projectManager        Agent?              @relation("CustomerPM", fields: [projectManagerAgentId], references: [id])
  tenant                Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  records               ITSMRecord[]
  notificationRules     NotificationRule[]
  users                 User[]              @relation("CustomerUsers")

  @@index([tenantId])
  @@index([status])
  @@map("customers")
}

model CustomerAgent {
  customerId String   @map("customer_id")
  agentId    String   @map("agent_id")
  createdAt  DateTime @default(now()) @map("created_at")
  agent      Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@id([customerId, agentId])
  @@map("customer_agents")
}

model SupportTypeMaster {
  id                   String                 @id @default(uuid())
  tenantId             String                 @map("tenant_id")
  name                 String
  code                 String
  description          String?
  color                String?                @default("#6366f1")
  workDays             Int[]                  @map("work_days")
  weekendCoverage      WeekendCoverageType    @default(NONE) @map("weekend_coverage")
  holidayCoverage      HolidayCoverageType    @default(NONE) @map("holiday_coverage")
  afterHoursCoverage   AfterHoursCoverageType @default(NONE) @map("after_hours_coverage")
  weekendMultiplier    Float                  @default(2.0) @map("weekend_multiplier")
  holidayMultiplier    Float                  @default(2.0) @map("holiday_multiplier")
  afterHoursMultiplier Float                  @default(1.5) @map("after_hours_multiplier")
  slaPauseConditions   String[]               @default([]) @map("sla_pause_conditions")
  onCallPriorities     String[]               @default([]) @map("on_call_priorities")
  priorityScope        PriorityScope          @default(ALL) @map("priority_scope")
  slaEnabled           Json                   @default("{\"P1\": true, \"P2\": true, \"P3\": true, \"P4\": true}") @map("sla_enabled")
  isActive             Boolean                @default(true) @map("is_active")
  createdAt            DateTime               @default(now()) @map("created_at")
  updatedAt            DateTime               @updatedAt @map("updated_at")
  contracts            Contract[]
  tenant               Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("support_type_masters")
}

model SLAPolicyMaster {
  id               String     @id @default(uuid())
  tenantId         String     @map("tenant_id")
  name             String
  code             String
  description      String?
  color            String?    @default("#6366f1")
  warningThreshold Float      @default(0.80) @map("warning_threshold")
  priorities       Json       @default("{}") @map("priorities")
  isActive         Boolean    @default(true) @map("is_active")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")
  contracts        Contract[]
  tenant           Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("sla_policy_masters")
}

model SAPModuleMaster {
  id                   String                @id @default(uuid())
  tenantId             String                @map("tenant_id")
  code                 String
  name                 String
  description          String?
  sortOrder            Int                   @default(0) @map("sort_order")
  isActive             Boolean               @default(true) @map("is_active")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  agentSpecializations AgentSpecialization[]
  assignmentRules      AssignmentRule[]
  records              ITSMRecord[]          @relation("RecordSAPModule")
  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subModules           SAPSubModuleMaster[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("sap_module_masters")
}

model SAPSubModuleMaster {
  id          String          @id @default(uuid())
  tenantId    String          @map("tenant_id")
  moduleId    String          @map("module_id")
  code        String
  name        String
  description String?
  sortOrder   Int             @default(0) @map("sort_order")
  isActive    Boolean         @default(true) @map("is_active")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  records     ITSMRecord[]    @relation("RecordSAPSubModule")
  module      SAPModuleMaster @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, moduleId, code])
  @@index([tenantId, moduleId])
  @@map("sap_sub_module_masters")
}

model Contract {
  id                  String                    @id @default(uuid())
  customerId          String                    @map("customer_id")
  contractNumber      String                    @unique @map("contract_number")
  supportTypeMasterId String?                   @map("support_type_master_id")
  slaPolicyMasterId   String?                   @map("sla_policy_master_id")
  startDate           DateTime                  @map("start_date")
  endDate             DateTime                  @map("end_date")
  autoRenewal         Boolean                   @default(false) @map("auto_renewal")
  renewalNoticeDays   Int                       @default(60) @map("renewal_notice_days")
  billingAmount       Decimal                   @map("billing_amount")
  currency            String                    @default("USD")
  billingFrequency    String                    @default("Monthly") @map("billing_frequency")
  paymentTerms        String                    @default("Net 30") @map("payment_terms")
  notes               String?
  createdAt           DateTime                  @default(now()) @map("created_at")
  updatedAt           DateTime                  @updatedAt @map("updated_at")
  holidayCalendars    ContractHolidayCalendar[]
  shifts              ContractShift[]
  customer            Customer                  @relation(fields: [customerId], references: [id])
  slaPolicyMaster     SLAPolicyMaster?          @relation(fields: [slaPolicyMasterId], references: [id])
  supportTypeMaster   SupportTypeMaster?        @relation(fields: [supportTypeMasterId], references: [id])
  records             ITSMRecord[]

  @@index([customerId])
  @@index([endDate])
  @@map("contracts")
}

model Shift {
  id           String          @id @default(uuid())
  tenantId     String          @map("tenant_id")
  name         String
  startTime    String          @map("start_time")
  endTime      String          @map("end_time")
  timezone     String          @default("UTC")
  breakMinutes Int             @default(0) @map("break_minutes")
  status       String          @default("active")
  metadata     Json?           @default("{}")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  contracts    ContractShift[]
  tenant       Tenant          @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("shifts")
}

model ContractShift {
  contractId String   @map("contract_id")
  shiftId    String   @map("shift_id")
  createdAt  DateTime @default(now()) @map("created_at")
  contract   Contract @relation(fields: [contractId], references: [id])
  shift      Shift    @relation(fields: [shiftId], references: [id])

  @@id([contractId, shiftId])
  @@map("contract_shifts")
}

model HolidayCalendar {
  id        String                    @id @default(uuid())
  tenantId  String                    @map("tenant_id")
  name      String
  country   String
  year      Int
  isActive  Boolean                   @default(true) @map("is_active")
  createdAt DateTime                  @default(now()) @map("created_at")
  contracts ContractHolidayCalendar[]
  tenant    Tenant                    @relation(fields: [tenantId], references: [id])
  dates     HolidayDate[]

  @@index([tenantId])
  @@index([country, year])
  @@map("holiday_calendars")
}

model HolidayDate {
  id          String             @id @default(uuid())
  calendarId  String             @map("calendar_id")
  date        DateTime
  name        String
  supportType HolidaySupportType @default(NONE) @map("support_type")
  calendar    HolidayCalendar    @relation(fields: [calendarId], references: [id])

  @@index([calendarId])
  @@index([date])
  @@map("holiday_dates")
}

model ContractHolidayCalendar {
  contractId        String          @map("contract_id")
  holidayCalendarId String          @map("holiday_calendar_id")
  createdAt         DateTime        @default(now()) @map("created_at")
  contract          Contract        @relation(fields: [contractId], references: [id])
  holidayCalendar   HolidayCalendar @relation(fields: [holidayCalendarId], references: [id])

  @@id([contractId, holidayCalendarId])
  @@map("contract_holiday_calendars")
}

model ConfigurationItem {
  id          String       @id @default(uuid())
  tenantId    String       @map("tenant_id")
  customerId  String?      @map("customer_id")
  ciType      CIType       @map("ci_type")
  name        String
  environment String?
  sid         String?
  hostname    String?
  version     String?
  metadata    Json?        @default("{}")
  status      CIStatus     @default(ACTIVE)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  customer    Customer?    @relation(fields: [customerId], references: [id])
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  records     ITSMRecord[]

  @@index([tenantId])
  @@index([tenantId, customerId])
  @@index([ciType])
  @@index([status])
  @@map("configuration_items")
}

model ITSMRecord {
  id              String              @id @default(uuid())
  tenantId        String              @map("tenant_id")
  recordType      RecordType          @map("record_type")
  recordNumber    String              @unique @map("record_number")
  title           String
  description     String
  priority        Priority            @default(P3)
  status          RecordStatus        @default(NEW)
  customerId      String?             @map("customer_id")
  contractId      String?             @map("contract_id")
  assignedAgentId String?             @map("assigned_agent_id")
  ciId            String?             @map("ci_id")
  parentProblemId String?             @map("parent_problem_id")
  createdById     String              @map("created_by")
  tags            String[]            @default([])
  sapModuleId     String?             @map("sap_module_id")
  sapSubModuleId  String?             @map("sap_sub_module_id")
  metadata        Json?               @default("{}")
  resolvedAt      DateTime?           @map("resolved_at")
  closedAt        DateTime?           @map("closed_at")
  respondedAt     DateTime?           @map("responded_at")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  auditLogs       AuditLog[]
  comments        Comment[]
  emailLogs       EmailLog[]
  assignedAgent   Agent?              @relation(fields: [assignedAgentId], references: [id])
  ci              ConfigurationItem?  @relation(fields: [ciId], references: [id])
  contract        Contract?           @relation(fields: [contractId], references: [id])
  createdBy       User                @relation("CreatedBy", fields: [createdById], references: [id])
  customer        Customer?           @relation(fields: [customerId], references: [id])
  parentProblem   ITSMRecord?         @relation("ProblemIncidents", fields: [parentProblemId], references: [id])
  linkedIncidents ITSMRecord[]        @relation("ProblemIncidents")
  sapModule       SAPModuleMaster?    @relation("RecordSAPModule", fields: [sapModuleId], references: [id])
  sapSubModule    SAPSubModuleMaster? @relation("RecordSAPSubModule", fields: [sapSubModuleId], references: [id])
  tenant          Tenant              @relation(fields: [tenantId], references: [id])
  notifications   Notification[]
  slaTracking     SLATracking?
  timeEntries     TimeEntry[]

  @@index([tenantId])
  @@index([recordType])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@index([assignedAgentId])
  @@index([customerId])
  @@map("itsm_records")
}

model SLATracking {
  id                    String            @id @default(uuid())
  recordId              String            @unique @map("record_id")
  responseDeadline      DateTime          @map("response_deadline")
  resolutionDeadline    DateTime          @map("resolution_deadline")
  respondedAt           DateTime?         @map("responded_at")
  pausedAt              DateTime?         @map("paused_at")
  pausedMinutes         Int               @default(0) @map("paused_minutes")
  breachResponse        Boolean           @default(false) @map("breach_response")
  breachResolution      Boolean           @default(false) @map("breach_resolution")
  warningResponseSent   Boolean           @default(false) @map("warning_response_sent")
  warningResolutionSent Boolean           @default(false) @map("warning_resolution_sent")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  pauseHistory          SLAPauseHistory[]
  record                ITSMRecord        @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@index([responseDeadline])
  @@index([resolutionDeadline])
  @@map("sla_tracking")
}

model SLAPauseHistory {
  id             String      @id @default(uuid())
  slaId          String      @map("sla_id")
  pausedAt       DateTime    @map("paused_at")
  resumedAt      DateTime?   @map("resumed_at")
  reason         String?
  pausedByUserId String?     @map("paused_by_user_id")
  sla            SLATracking @relation(fields: [slaId], references: [id], onDelete: Cascade)

  @@index([slaId])
  @@map("sla_pause_history")
}

model TimeEntry {
  id           String          @id @default(uuid())
  recordId     String          @map("record_id")
  agentId      String          @map("agent_id")
  hours        Decimal
  description  String
  workDate     DateTime        @map("work_date")
  status       TimeEntryStatus @default(PENDING)
  approvedById String?         @map("approved_by")
  approvedAt   DateTime?       @map("approved_at")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  agent        Agent           @relation(fields: [agentId], references: [id])
  approvedBy   User?           @relation("ApprovedBy", fields: [approvedById], references: [id])
  record       ITSMRecord      @relation(fields: [recordId], references: [id])

  @@index([recordId])
  @@index([agentId])
  @@index([status])
  @@map("time_entries")
}

model Comment {
  id           String     @id @default(uuid())
  recordId     String     @map("record_id")
  authorId     String     @map("author_id")
  text         String
  internalFlag Boolean    @default(false) @map("internal_flag")
  attachments  Json?      @default("[]")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  author       User       @relation(fields: [authorId], references: [id])
  record       ITSMRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@index([recordId])
  @@map("comments")
}

model EmailLog {
  id          String      @id @default(uuid())
  recordId    String?     @map("record_id")
  templateKey String      @map("template_key")
  subject     String
  recipient   String
  cc          String[]    @default([])
  body        String
  status      EmailStatus @default(PENDING)
  sentAt      DateTime?   @map("sent_at")
  error       String?
  retryCount  Int         @default(0) @map("retry_count")
  createdAt   DateTime    @default(now()) @map("created_at")
  record      ITSMRecord? @relation(fields: [recordId], references: [id])

  @@index([recordId])
  @@index([status])
  @@index([createdAt])
  @@map("email_logs")
}

model AuditLog {
  id         String      @id @default(uuid())
  tenantId   String?     @map("tenant_id")
  userId     String?     @map("user_id")
  recordId   String?     @map("record_id")
  action     AuditAction
  entityType String      @map("entity_type")
  entityId   String      @map("entity_id")
  oldValues  Json?       @map("old_values")
  newValues  Json?       @map("new_values")
  ipAddress  String?     @map("ip_address")
  userAgent  String?     @map("user_agent")
  metadata   Json?       @default("{}")
  createdAt  DateTime    @default(now()) @map("created_at")
  record     ITSMRecord? @relation(fields: [recordId], references: [id])
  tenant     Tenant?     @relation(fields: [tenantId], references: [id])
  user       User?       @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([recordId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
  @@map("audit_logs")
}

model EmailTemplate {
  id              String             @id @default(uuid())
  tenantId        String             @map("tenant_id")
  templateKey     String             @map("template_key")
  label           String
  description     String?
  subjectTemplate String             @map("subject_template")
  bodyTemplate    String             @map("body_template")
  isActive        Boolean            @default(true) @map("is_active")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  tenant          Tenant             @relation(fields: [tenantId], references: [id])
  escalationRules NotificationRule[] @relation("EscalationTemplate")
  primaryRules    NotificationRule[] @relation("PrimaryTemplate")
  secondaryRules  NotificationRule[] @relation("SecondaryTemplate")

  @@unique([tenantId, templateKey])
  @@map("email_templates")
}

model NotificationRule {
  id                   String         @id @default(uuid())
  tenantId             String         @map("tenant_id")
  customerId           String?        @map("customer_id")
  event                String
  priority             String?
  statusFilter         String?        @map("status_filter")
  recipients           Json           @default("[]")
  primaryTemplateId    String?        @map("primary_template_id")
  secondaryTemplateId  String?        @map("secondary_template_id")
  escalationTemplateId String?        @map("escalation_template_id")
  emailEnabled         Boolean        @default(true) @map("email_enabled")
  inAppEnabled         Boolean        @default(true) @map("in_app_enabled")
  isActive             Boolean        @default(true) @map("is_active")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")
  customer             Customer?      @relation(fields: [customerId], references: [id])
  escalationTemplate   EmailTemplate? @relation("EscalationTemplate", fields: [escalationTemplateId], references: [id])
  primaryTemplate      EmailTemplate? @relation("PrimaryTemplate", fields: [primaryTemplateId], references: [id])
  secondaryTemplate    EmailTemplate? @relation("SecondaryTemplate", fields: [secondaryTemplateId], references: [id])
  tenant               Tenant         @relation(fields: [tenantId], references: [id])

  @@index([tenantId, event])
  @@index([tenantId, customerId, event])
  @@map("notification_rules")
}

model Notification {
  id        String      @id @default(uuid())
  tenantId  String      @map("tenant_id")
  userId    String      @map("user_id")
  recordId  String?     @map("record_id")
  event     String
  title     String
  body      String
  isRead    Boolean     @default(false) @map("is_read")
  readAt    DateTime?   @map("read_at")
  createdAt DateTime    @default(now()) @map("created_at")
  record    ITSMRecord? @relation(fields: [recordId], references: [id])
  tenant    Tenant      @relation(fields: [tenantId], references: [id])
  user      User        @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([tenantId])
  @@map("notifications")
}

model NotificationPreference {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  event     String
  email     Boolean  @default(true)
  inApp     Boolean  @default(true) @map("in_app")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, event])
  @@map("notification_preferences")
}

